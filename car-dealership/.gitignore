# ── Terraform ─────────────────────────────────────────────────────────────────
*.tfstate
*.tfstate.*
*.tfvars               # NEVER commit real tfvars
!*.tfvars.example      # but do commit the example
.terraform/
.terraform.lock.hcl
tfplan
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── Node / Next.js ─────────────────────────────────────────────────────────────
node_modules/
.next/
out/
*.log
npm-debug.log*
.env
.env.local
.env.*.local
frontend/.env*
!frontend/.env.example

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
backend/.env
!backend/.env.example

# ── Secrets (belt + suspenders) ───────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*secret*
*password*
*credential*
*_creds*
kubeconfig
.kube/

# ── Docker ─────────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── IDE / OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
